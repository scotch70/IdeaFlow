# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for invite links, Stripe redirect URLs, etc.
# No trailing slash.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=IdeaFlow <ideaflow@appstimize.nl>

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key — Stripe Dashboard → Developers → API keys → Secret key
# Use sk_test_… locally, sk_live_… in production.
STRIPE_SECRET_KEY=sk_test_...

# Price ID of the yearly Pro product.
# Create two products in Stripe Dashboard:
#   1. "IdeaFlow Standard" — Yearly, EUR 49.00
#   2. "IdeaFlow Pro"      — Yearly, EUR 99.00
# Copy each price ID: price_…
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks
# Add endpoint: https://yourdomain.com/api/stripe/webhook
# Select events: checkout.session.completed,
#                customer.subscription.updated,
#                customer.subscription.deleted
# Copy the signing secret: whsec_…
STRIPE_WEBHOOK_SECRET=whsec_...
